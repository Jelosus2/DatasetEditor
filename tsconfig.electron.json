{
    "extends": "@tsconfig/node22",
    "include": ["app/**/*"],
    "compilerOptions": {
        "module": "nodenext",
        "target": "es2023",
        "rootDir": "app",
        "outDir": "dist-electron",
        "types": ["node", "electron"],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "useDefineForClassFields": false
    }
}