{
  "name": "dataset-editor",
  "version": "1.0.1",
  "type": "module",
  "main": "dist_app/main.js",
  "description": "A dataset editor",
  "author": "Jelosus1 <navarrorodriguezjesus6@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "electron": "pnpm build:electron && electron .",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "package:win": "vite build && pnpm build:electron && electron-builder build --win --publish never",
    "package:linux": "vite build && pnpm build:electron && electron-builder build --linux --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@tailwindcss/vite": "^4.0.6",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.5.0",
    "dtext-parser": "^1.0.0",
    "electron-updater": "^6.7.3",
    "fs-extra": "^11.3.3",
    "lodash": "^4.17.21",
    "pinia": "^3.0.1",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.21",
    "@types/node": "^22.13.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.3.0",
    "@vue/tsconfig": "^0.7.0",
    "daisyui": "5.5.14",
    "electron": "^39.2.7",
    "electron-builder": "^26.3.6",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "jiti": "^2.4.2",
    "npm-run-all2": "^7.0.2",
    "typescript": "~5.9.3",
    "vite": "^6.0.11",
    "vite-svg-loader": "^5.1.0",
    "vue-tsc": "^2.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jelosus2/DatasetEditor.git"
  }
}
